# Dockerfile for running frontend unit tests
FROM node:20-alpine
WORKDIR /app

# Install pinned dependencies from the lockfile (reproducible, fails fast
# if package.json and package-lock.json drift apart).
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

# Copy source and config
COPY frontend/ ./

# Run Vitest in non-watch mode
CMD ["npm", "run", "test"]
