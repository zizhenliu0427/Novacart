# Production environment template for:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build

DB_HOST=your-rds-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

DB_AUTH_CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=novacart_auth;Username=${DB_USER};Password=${DB_PASSWORD}
DB_PRODUCT_CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=novacart_product;Username=${DB_USER};Password=${DB_PASSWORD}
DB_COMMERCE_CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=novacart_commerce;Username=${DB_USER};Password=${DB_PASSWORD}
DB_CART_CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=novacart_cart;Username=${DB_USER};Password=${DB_PASSWORD}

REDIS_CONNECTION_STRING=your-elasticache:6379
RABBITMQ_CONNECTION_STRING=amqp://user:pass@your-amq:5672
RABBITMQ_MANAGEMENT_URL=https://your-amq:15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=CHANGE_ME

JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-chars
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

AWS_S3_BUCKET=novacart-product-images
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com/novacart

OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
