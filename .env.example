# ─── Novacart Environment Variables ──────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit .env to git.
# Used by docker-compose.prod.yml for production deployments.

# ── Database (PostgreSQL / RDS) ──────────────────────────────────
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=novacart;Username=postgres;Password=postgres
# Production example:
# DB_CONNECTION_STRING=Host=your-rds.amazonaws.com;Port=5432;Database=novacart;Username=novacart_app;Password=CHANGE_ME

# ── Redis (ElastiCache) ─────────────────────────────────────────
REDIS_CONNECTION_STRING=localhost:6379

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-chars
JWT_ISSUER=novacart
JWT_AUDIENCE=novacart

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Square (Catalogue Sync) ─────────────────────────────────────
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_ENVIRONMENT=sandbox

# ── SMTP (Email — P2-6) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@novacart.com
SMTP_FROM_NAME=Novacart

# ── ngrok (dev webhook tunnelling) ───────────────────────────────
NGROK_URL=https://your-ngrok-url.ngrok-free.app
