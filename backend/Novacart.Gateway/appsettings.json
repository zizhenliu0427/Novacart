{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "RateLimiting": {
    "CheckoutPermitLimit": 30,
    "CheckoutWindowSeconds": 60,
    "CheckoutQueueLimit": 10,
    "DefaultPermitLimit": 300,
    "DefaultWindowSeconds": 60,
    "ChatPermitLimit": 10,
    "ChatWindowSeconds": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "products-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "currency-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/currency/{**catch-all}" }
      },
      "admin-products-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/admin/products/{**catch-all}" }
      },
      "admin-price-rules-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/admin/price-rules/{**catch-all}" }
      },
      "admin-analytics-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/admin/analytics/{**catch-all}" }
      },
      "admin-uploads-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/admin/uploads/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/cart/{**catch-all}" }
      },
      "wishlist-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/wishlist/{**catch-all}" }
      },
      "checkout-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/checkout/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "address-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/address/{**catch-all}" }
      },
      "admin-orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/admin/orders/{**catch-all}" }
      },
      "admin-system-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/admin/system/{**catch-all}" }
      },
      "support-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/support/{**catch-all}" }
      },
      "health-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/health" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "https+http://auth-api" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product": { "Address": "https+http://product-api" }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart": { "Address": "https+http://cart-api" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order": { "Address": "https+http://order-api" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
